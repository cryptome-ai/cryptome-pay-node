{
  "name": "cryptomepay",
  "version": "1.0.0",
  "description": "Official Node.js SDK for Cryptome Pay - Non-custodial cryptocurrency payment gateway",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cryptome",
    "cryptomepay",
    "crypto",
    "payment",
    "gateway",
    "usdt",
    "trc20",
    "bsc",
    "polygon",
    "ethereum",
    "arbitrum",
    "cryptocurrency",
    "blockchain"
  ],
  "author": "Cryptome AI <support@cryptomepay.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cryptome-ai/cryptome-pay-node.git"
  },
  "bugs": {
    "url": "https://github.com/cryptome-ai/cryptome-pay-node/issues"
  },
  "homepage": "https://github.com/cryptome-ai/cryptome-pay-node#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
